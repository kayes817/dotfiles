#!/usr/bin/env sh
set -eu

current_id="$(hyprctl activeworkspace -j | jq -r '.id')"
hyprctl clients -j \
  | jq -r --argjson ws "$current_id" '.[] | select(.workspace.id == $ws and .floating == true) | .address' \
  | while read -r addr; do
      [ -n "$addr" ] || continue
      hyprctl dispatch settiled "address:$addr" >/dev/null
    done
